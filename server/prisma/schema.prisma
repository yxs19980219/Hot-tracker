generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Keyword {
  id             String        @id @default(uuid())
  text           String        @unique
  category       String?
  isActive       Boolean       @default(true)
  trackingPrompt String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  hotspots       Hotspot[]
  trackedItems   TrackedItem[] @relation("KeywordTrackedItems")
}

model Hotspot {
  id               String    @id @default(uuid())
  title            String
  content          String
  url              String
  source           String
  sourceId         String?
  isReal           Boolean   @default(true)
  relevance        Int       @default(0)
  relevanceReason  String?
  keywordMentioned Boolean?
  importance       String    @default("low")
  summary          String?
  viewCount        Int?
  likeCount        Int?
  retweetCount     Int?
  replyCount       Int?
  commentCount     Int?
  quoteCount       Int?
  danmakuCount     Int?
  authorName       String?
  authorUsername   String?
  authorAvatar     String?
  authorFollowers  Int?
  authorVerified   Boolean?
  publishedAt      DateTime?
  createdAt        DateTime  @default(now())
  keywordId        String?
  keyword          Keyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)

  @@unique([url, source])
}

model Notification {
  id            String   @id @default(uuid())
  type          String
  title         String
  content       String
  isRead        Boolean  @default(false)
  hotspotId     String?
  trackedItemId String?
  createdAt     DateTime @default(now())
}

model Setting {
  id    String @id @default(uuid())
  key   String @unique
  value String
}

// ========== 追踪项（长期追踪库） ==========

model TrackedItem {
  id            String              @id @default(uuid())
  title         String
  canonicalUrl  String              @unique
  url           String              // 用户输入的原始 URL
  note          String?
  trackingPrompt String?
  isActive      Boolean             @default(true)
  lastCheckedAt DateTime?
  lastUpdateAt  DateTime?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  sources       TrackedItemSource[]
  updates       TrackedItemUpdate[]
  keywords      Keyword[]           @relation("KeywordTrackedItems")
}

// ========== 追踪源（系统内部使用） ==========

model TrackedItemSource {
  id              String      @id @default(uuid())
  trackedItemId   String
  trackedItem     TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  type            String      // 'github_repo' | 'rss' | 'changelog_page'
  url             String
  config          String?     // JSON 配置

  isActive        Boolean     @default(true)
  lastContentHash String?
  lastCheckedAt   DateTime?
  lastUpdateAt    DateTime?
  createdAt       DateTime    @default(now())
}

// ========== 更新记录 ==========

model TrackedItemUpdate {
  id            String      @id @default(uuid())
  trackedItemId String
  trackedItem   TrackedItem @relation(fields: [trackedItemId], references: [id], onDelete: Cascade)

  updateType    String
  title         String
  content       String
  aiSummary     String?
  aiAction      String?

  sourceUrl     String?
  isNotified    Boolean     @default(false)
  createdAt     DateTime    @default(now())
}

// ========== GitHub Trending 缓存 ==========

model GithubTrending {
  id          String   @id @default(uuid())
  repoName    String   @unique
  description String?
  language    String?
  starsToday  Int?
  totalStars  Int?
  url         String
  fetchedAt   DateTime @default(now())
}
